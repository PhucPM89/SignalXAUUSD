# ── Database (Railway Postgres plugin hoặc external) ──────────────────────────
# Railway tự inject DATABASE_URL — copy vào đây nếu dùng external
ConnectionStrings__Postgres=Host=YOUR_HOST;Database=signal;Username=signal;Password=YOUR_PASS

# ── Redis (Railway Redis plugin hoặc Upstash free tier) ───────────────────────
# Upstash free: https://upstash.com → Create Redis → lấy connection string
ConnectionStrings__Redis=YOUR_REDIS_HOST:6379,password=YOUR_REDIS_PASS,ssl=true,abortConnect=false

# ── JWT (tạo random 64-char string) ───────────────────────────────────────────
# Generate: openssl rand -base64 64
Jwt__Key=CHANGE_ME_RANDOM_64_CHAR_SECRET
Jwt__Issuer=signal-api
Jwt__Audience=signal-dashboard

# ── Market Data APIs ───────────────────────────────────────────────────────────
# Twelve Data (đã có): https://twelvedata.com → My API
MarketData__TwelveDataApiKey=YOUR_TWELVE_DATA_KEY

# Polygon.io (free tier): https://polygon.io → Dashboard → API Keys
MarketData__PolygonApiKey=YOUR_POLYGON_KEY

# Finnhub (free): https://finnhub.io → My API
News__FinnhubApiKey=YOUR_FINNHUB_KEY

# ── Signal Engine URL (service nội bộ trong Railway) ──────────────────────────
SignalEngine__BaseUrl=http://signal-engine.railway.internal:8000
SignalEngine__TimeoutSeconds=8

# ── Kafka (tắt cho cloud deploy không có Kafka) ────────────────────────────────
Kafka__Enabled=false

# ── CORS (domain của frontend trên Railway/Vercel) ───────────────────────────
AllowedOrigins__0=https://YOUR_FRONTEND_DOMAIN.up.railway.app
# Nếu dùng Vercel:
# AllowedOrigins__0=https://YOUR_APP.vercel.app

# ── ASP.NET Core ──────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_HTTP_PORTS=8080
